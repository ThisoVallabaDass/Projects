{
  "info": {
    "name": "TinyTrail API",
    "description": "TinyTrail Marketplace API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\",\n  \"email\": \"test@example.com\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', response.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Search Products by Pincode",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products/search?pincode=600001",
              "host": ["{{base_url}}"],
              "path": ["products", "search"],
              "query": [
                {
                  "key": "pincode",
                  "value": "600001"
                }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products/1",
              "host": ["{{base_url}}"],
              "path": ["products", "1"]
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Fresh Apples",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Fresh red apples from local farm",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "60.00",
                  "type": "text"
                },
                {
                  "key": "pincode",
                  "value": "600001",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "Fruits",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products/categories",
              "host": ["{{base_url}}"],
              "path": ["products", "categories"]
            }
          }
        }
      ]
    },
    {
      "name": "Seller",
      "item": [
        {
          "name": "Seller Onboarding",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shopName\": \"My Fresh Store\",\n  \"pincode\": \"600001\",\n  \"address\": \"123 Main Street, Chennai\",\n  \"description\": \"Fresh vegetables and fruits\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/seller/onboard",
              "host": ["{{base_url}}"],
              "path": ["seller", "onboard"]
            }
          }
        },
        {
          "name": "Get Seller Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/seller/profile",
              "host": ["{{base_url}}"],
              "path": ["seller", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deliveryAddress\": \"123 Oak Street, Chennai\",\n  \"paymentMethod\": \"UPI\",\n  \"upiId\": \"test@upi\",\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 2,\n      \"price\": 50.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": ["{{base_url}}"],
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Get Buyer Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/orders/buyer",
              "host": ["{{base_url}}"],
              "path": ["orders", "buyer"]
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/orders/1",
              "host": ["{{base_url}}"],
              "path": ["orders", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Payment Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": 1,\n  \"status\": \"SUCCESS\",\n  \"txnId\": \"UPI-TEST-001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhooks/payment",
              "host": ["{{base_url}}"],
              "path": ["webhooks", "payment"]
            }
          }
        },
        {
          "name": "Delivery Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": 1,\n  \"status\": \"DELIVERED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhooks/delivery",
              "host": ["{{base_url}}"],
              "path": ["webhooks", "delivery"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Seed Data",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/admin/seed",
              "host": ["{{base_url}}"],
              "path": ["admin", "seed"]
            }
          }
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/orders",
              "host": ["{{base_url}}"],
              "path": ["admin", "orders"]
            }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{base_url}}/admin/orders/1/status?status=CONFIRMED",
              "host": ["{{base_url}}"],
              "path": ["admin", "orders", "1", "status"],
              "query": [
                {
                  "key": "status",
                  "value": "CONFIRMED"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
