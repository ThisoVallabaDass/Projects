# TinyTrail Environment Configuration
# Copy this to .env and fill in your values

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/tinytrail
DB_USER=tinytrail_user
DB_PASS=change_me_in_production

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI Service Integration
# TODO: Set this to your OpenAI, Anthropic, or other LLM API key
AI_API_KEY=

# Maps Integration
# TODO: Add Google Maps or Leaflet API key if using Google Maps
MAPS_API_KEY=

# AWS S3 Storage (Optional - for production image storage)
STORAGE_S3_BUCKET=
STORAGE_S3_KEY=
STORAGE_S3_SECRET=
STORAGE_S3_REGION=us-east-1

# Payment Gateway (TODO: Add Razorpay or PhonePe credentials)
PAYMENT_API_KEY=
PAYMENT_API_SECRET=

# Server Configuration
SERVER_PORT=8080
NODE_ENV=development

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8080
REACT_APP_WS_URL=ws://localhost:8080
