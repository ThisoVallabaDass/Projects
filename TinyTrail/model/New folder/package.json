{
  "name": "tinytrail-fullstack",
  "version": "1.0.0",
  "description": "TinyTrail - Complete Full-Stack Marketplace Application",
  "main": "packages/backend/server.js",
  "scripts": {
    "install-all": "npm install && cd packages/backend && npm install && cd ../web && npm install && cd ../mobile && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:web\" \"npm run dev:mobile\"",
    "dev:backend": "cd packages/backend && npm run dev",
    "dev:web": "cd packages/web && npm start",
    "dev:mobile": "cd packages/mobile && npm start",
    "build": "npm run build:backend && npm run build:web && npm run build:mobile",
    "build:backend": "cd packages/backend && npm run build",
    "build:web": "cd packages/web && npm run build",
    "build:mobile": "cd packages/mobile && npm run build",
    "test": "concurrently \"npm run test:backend\" \"npm run test:web\"",
    "test:backend": "cd packages/backend && npm test",
    "test:web": "cd packages/web && npm test",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
